---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('/src/content/posts/*.{md,mdx}', { eager: true });
  return Object.entries(modules).flatMap(([path, mod]) => {
    const typed = mod as { frontmatter?: Record<string, any>; default?: any };
    const fileSlug = (path.split('/').pop() ?? '').replace(/\.(md|mdx)$/i, '');
    const slug = String(typed.frontmatter?.slug ?? fileSlug);
    return slug
      ? [{ params: { slug }, props: { post: { data: typed.frontmatter ?? {}, Content: typed.default } } }]
      : [];
  });
}

const { post } = Astro.props;
const Content = post.Content;

function formatDate(date: Date | string) {
  return new Date(date).toLocaleDateString('en-AU', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<Base title={`${post.data.title} — Build log`}>
  <div class="container">
    <div class="page-header">
      <a href="/" class="back-link">← Home</a>
      {post.data.outcome && (
        <div style="margin-bottom: 1rem;">
          <span class={`badge badge-${post.data.outcome}`}>
            {post.data.outcome}
          </span>
        </div>
      )}
      <h1>{post.data.title}</h1>
      <div class="page-meta" style="margin-top: 1rem;">
        <span class="page-date">{formatDate(post.data.date)}</span>
        {post.data.project && (
          <a href={`/project/${post.data.project}`}
             style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text3); letter-spacing: 0.05em;">
            → {post.data.project}
          </a>
        )}
      </div>
    </div>

    <div class="col">
      <article class="prose">
        {Content && <Content />}
      </article>
    </div>
  </div>
</Base>
